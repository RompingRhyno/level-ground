// Prisma schema for Vercel Postgres
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Page {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  label     String
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id         String   @id @default(uuid())
  storageKey String
  provider   String
  folder     String?
  tags       String[]
  size       Int?
  publicUrl  String?
  filename   String?
  mime       String?
  width      Int?
  height     Int?
  alt        String?
  meta       Json?
  migrated   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([provider])
}

model Folder {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  parentId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([slug])
}
